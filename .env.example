# Copy to .env and adjust as needed. All variables are optional; defaults shown.

# HTTP server
KRA_SERVER_HOST=0.0.0.0
KRA_SERVER_PORT=8080
KRA_SERVER_READ_TIMEOUT=10s
KRA_SERVER_WRITE_TIMEOUT=10s
KRA_SERVER_IDLE_TIMEOUT=60s
KRA_SERVER_SHUTDOWN_TIMEOUT=15s
KRA_SERVER_HEALTH_TIMEOUT=2s   # per-dependency probe budget for /health

# Kafka (comma-separated list of broker host:port)
KRA_KAFKA_BROKERS=localhost:9092
KRA_KAFKA_WRITE_TIMEOUT=10s
KRA_KAFKA_BATCH_TIMEOUT=10ms
KRA_KAFKA_REQUIRED_ACKS=all   # all | one | none
KRA_KAFKA_MAX_BATCH_SIZE=10000
# Ask the broker to create unknown topics on publish (off by default; safe for prod).
KRA_KAFKA_ALLOW_AUTO_TOPIC_CREATION=false
# Produce mode: batched (high throughput, no offsets) | sync (returns per-record offsets)
KRA_KAFKA_PRODUCE_MODE=batched

# Metadata / admin and consume limits
KRA_KAFKA_ADMIN_TIMEOUT=10s
KRA_KAFKA_CONSUME_DEFAULT_LIMIT=10
KRA_KAFKA_CONSUME_MAX_LIMIT=1000
KRA_KAFKA_CONSUME_DEFAULT_TIMEOUT=5s
KRA_KAFKA_CONSUME_MAX_TIMEOUT=30s

# Kafka security: plaintext | ssl | sasl_plaintext | sasl_ssl
KRA_KAFKA_SECURITY_PROTOCOL=plaintext
# SASL (used when protocol is sasl_*)
KRA_KAFKA_SASL_MECHANISM=scram-sha-256   # scram-sha-256 | scram-sha-512 | plain
KRA_KAFKA_SASL_USERNAME=
KRA_KAFKA_SASL_PASSWORD=
# TLS (used when protocol is ssl or sasl_ssl)
KRA_KAFKA_TLS_CA_FILE=
KRA_KAFKA_TLS_CERT_FILE=
KRA_KAFKA_TLS_KEY_FILE=
KRA_KAFKA_TLS_SERVER_NAME=
KRA_KAFKA_TLS_INSECURE_SKIP_VERIFY=false

# JWT auth for /topics routes (off by default).
KRA_AUTH_ENABLED=false
KRA_AUTH_ALGORITHM=hs256          # hs256 | rs256
# HS256 (shared secret)
KRA_AUTH_JWT_SECRET=
# RS256 (asymmetric) — set exactly one of:
KRA_AUTH_JWT_PUBLIC_KEY_FILE=     # static PEM public key
KRA_AUTH_JWKS_URL=                # JWKS endpoint (rotating keys)
# Optional claim checks
KRA_AUTH_JWT_ISSUER=
KRA_AUTH_JWT_AUDIENCE=

# Logging
KRA_LOG_LEVEL=info   # debug | info | warn | error
KRA_LOG_FORMAT=json  # json | text
